{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ClawHeart",
  "version": "2.0.0-alpha.0",
  "identifier": "live.clawheart.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClawHeart",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local AI Security Runtime",
    "longDescription": "ClawHeart Desktop v2 — protocol-agnostic AI security proxy with MCP deep inspection, skill supply chain trust, and fail-closed defense."
  }
}
